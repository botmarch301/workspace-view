#!/usr/bin/env bash
# spec-recipe commit-msg hook [Kitchen-only]
# 커밋 메시지의 영역 태그를 검증한다.
# pre-commit에서는 커밋 메시지에 접근할 수 없으므로 이 hook에서 처리.

COMMIT_MSG_FILE="$1"
SCRIPTS_DIR="scripts"

if [ ! -f "$COMMIT_MSG_FILE" ]; then
    exit 0
fi

COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# [init] 태그는 예외
if echo "$COMMIT_MSG" | grep -q '\[init\]'; then
    exit 0
fi

# 영역 태그 확인: [spec], [design], [dev], [test] 중 하나가 있어야 함
# 단, spec-recipe 관련 파일만 있는 커밋은 검증 대상
STAGED=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null)

if [ -z "$STAGED" ]; then
    exit 0
fi

# staged 파일 중 spec-recipe 관련 경로가 있는지 확인
HAS_MANAGED_FILES=0
for f in $STAGED; do
    case "$f" in
        .spec-recipe/*|spec/*|decisions/*|src/*|lib/*|app/*|config/*|tests/*|test/*)
            HAS_MANAGED_FILES=1
            break
            ;;
    esac
    # 테스트 파일 패턴
    if echo "$f" | grep -qE '(_test\.|_spec\.|test_)'; then
        HAS_MANAGED_FILES=1
        break
    fi
done

if [ "$HAS_MANAGED_FILES" -eq 0 ]; then
    exit 0
fi

# 태그 존재 확인
if ! echo "$COMMIT_MSG" | grep -qE '^\[(spec|design|dev|test|init)\]'; then
    echo "============================================================"
    echo "BLOCK: 커밋 메시지에 영역 태그가 필요합니다."
    echo "============================================================"
    echo "  형식: [spec|design|dev|test] 커밋 메시지"
    echo "  예시: [dev] 결제 모듈 구현"
    echo "  예시: [spec] FR-003 요구사항 추가"
    echo "  예시: [test] 결제 모듈 단위 테스트"
    echo "  예시: [init] spec-recipe 초기화"
    echo "============================================================"
    exit 1
fi

exit 0
